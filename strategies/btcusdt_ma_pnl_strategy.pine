//@version=6
strategy(
     "BTCUSDT MA PnL Strategy",
     overlay = true,
     initial_capital = 100000,
     currency = currency.USD,
     pyramiding = 0,
     commission_type = strategy.commission.percent,
     commission_value = 0.055,
     slippage = 2,
     margin_long = 2,
     margin_short = 2,
     process_orders_on_close = true)

fastLength = input.int(20, "Fast MA", minval = 1)
slowLength = input.int(50, "Slow MA", minval = 1)
tradeSide = input.string("Long only", "Trade side", options = ["Long only", "Short only", "Both"])

marginUsdt = input.float(200, "Margin USDT", minval = 1, step = 1)
leverage = input.float(50, "Leverage", minval = 1, maxval = 100, step = 1)
stopLossPnlPercent = input.float(50, "Stop loss PnL %", minval = 0.1, step = 0.1)
takeProfitPnlPercent = input.float(150, "Take profit PnL %", minval = 0.1, step = 0.1)

fastMa = ta.ema(close, fastLength)
slowMa = ta.ema(close, slowLength)

longSignal = ta.crossover(fastMa, slowMa)
shortSignal = ta.crossunder(fastMa, slowMa)

notionalUsdt = marginUsdt * leverage
qty = notionalUsdt / close

longStopFactor = 1 - (stopLossPnlPercent / 100) / leverage
longTakeProfitFactor = 1 + (takeProfitPnlPercent / 100) / leverage
shortStopFactor = 1 + (stopLossPnlPercent / 100) / leverage
shortTakeProfitFactor = 1 - (takeProfitPnlPercent / 100) / leverage

canLong = tradeSide == "Long only" or tradeSide == "Both"
canShort = tradeSide == "Short only" or tradeSide == "Both"

if longSignal and canLong
    strategy.entry("Long", strategy.long, qty = qty)

if shortSignal and canShort
    strategy.entry("Short", strategy.short, qty = qty)

if strategy.position_size > 0
    longStop = strategy.position_avg_price * longStopFactor
    longTakeProfit = strategy.position_avg_price * longTakeProfitFactor
    strategy.exit("Long exit", from_entry = "Long", stop = longStop, limit = longTakeProfit)

if strategy.position_size < 0
    shortStop = strategy.position_avg_price * shortStopFactor
    shortTakeProfit = strategy.position_avg_price * shortTakeProfitFactor
    strategy.exit("Short exit", from_entry = "Short", stop = shortStop, limit = shortTakeProfit)

plot(fastMa, "Fast MA", color = color.teal)
plot(slowMa, "Slow MA", color = color.orange)

plot(
     strategy.position_size > 0 ? strategy.position_avg_price * longStopFactor :
     strategy.position_size < 0 ? strategy.position_avg_price * shortStopFactor :
     na,
     "Stop loss",
     color = color.red,
     style = plot.style_linebr)

plot(
     strategy.position_size > 0 ? strategy.position_avg_price * longTakeProfitFactor :
     strategy.position_size < 0 ? strategy.position_avg_price * shortTakeProfitFactor :
     na,
     "Take profit",
     color = color.green,
     style = plot.style_linebr)
