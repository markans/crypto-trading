# Public market data source. Demo or live both work; only public endpoints are used.
BYBIT_BASE_URL=https://api-demo.bybit.com
# Optional override for public market data (defaults to live when BYBIT_BASE_URL is demo).
# BYBIT_MARKET_BASE_URL=https://api.bybit.com

# Email notifications for signals (optional; signals still print/log without it).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@example.com
SMTP_PASSWORD=your_app_password
SMTP_USE_TLS=true
EMAIL_FROM=you@example.com
EMAIL_TO=you@example.com
